#!/bin/sh
# prompt-nvim: open the current AI-tool prompt in Neovim.
# Used as the external editor ($VISUAL/$EDITOR) by terminal AI coding tools.

set -eu

VERSION="0.2.1"

target="${PROMPT_NVIM_TARGET:-}"
bridge="${PROMPT_NVIM_BRIDGE:-1}"
nvim_cmd="${PROMPT_NVIM_EXECUTABLE:-nvim}"
server="${PROMPT_NVIM_SERVER:-}"

script_dir=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)

usage() {
    cat <<'EOF'
prompt-nvim: Open the current AI-tool prompt in Neovim.

Usage: prompt-nvim [options] [--] <file> [args...]

Options:
  --target <name>        Select AI-tool target
  --target=<name>        Select AI-tool target
  --nvim <command>       Neovim executable to use (default: nvim)
  --server <address>     Open through an existing Neovim server (--remote-wait)
  --no-bridge            Disable bridge behavior
  --print-shell <shell>  Print shell integration (bash|zsh|fish|nu|nushell)
  --check                Validate the installation
  --help, -h             Show this help
  --version              Show version
EOF
}

print_shell() {
    _shell="$1"
    case "$_shell" in
        zsh) _file="zsh.sh" ;;
        bash) _file="bash.sh" ;;
        fish) _file="fish.fish" ;;
        nu | nushell) _file="nushell.nu" ;;
        *)
            printf '%s\n' "prompt-nvim: unknown shell: $_shell" >&2
            exit 2
            ;;
    esac
    _path="$script_dir/../shell/$_file"
    if [ ! -f "$_path" ]; then
        printf '%s\n' "prompt-nvim: shell integration file not found: $_path" >&2
        exit 1
    fi
    cat "$_path"
}

check() {
    _resolved=$(command -v "$nvim_cmd" 2>/dev/null || true)
    if [ -n "$_resolved" ]; then
        printf '%s\n' "prompt-nvim: nvim found: $_resolved"
        printf '%s\n' "prompt-nvim: OK"
        return 0
    fi
    printf '%s\n' "prompt-nvim: nvim not found: $nvim_cmd" >&2
    return 1
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --target)
            [ "$#" -ge 2 ] || {
                printf '%s\n' "prompt-nvim: --target requires a value" >&2
                exit 2
            }
            target="$2"
            shift 2
            ;;
        --target=*)
            target="${1#--target=}"
            shift
            ;;
        --nvim)
            [ "$#" -ge 2 ] || {
                printf '%s\n' "prompt-nvim: --nvim requires a value" >&2
                exit 2
            }
            nvim_cmd="$2"
            shift 2
            ;;
        --server)
            [ "$#" -ge 2 ] || {
                printf '%s\n' "prompt-nvim: --server requires a value" >&2
                exit 2
            }
            server="$2"
            shift 2
            ;;
        --no-bridge)
            bridge=0
            shift
            ;;
        --print-shell)
            [ "$#" -ge 2 ] || {
                printf '%s\n' "prompt-nvim: --print-shell requires a value" >&2
                exit 2
            }
            print_shell "$2"
            exit 0
            ;;
        --check)
            check
            exit "$?"
            ;;
        --help | -h)
            usage
            exit 0
            ;;
        --version)
            printf '%s\n' "prompt-nvim $VERSION"
            exit 0
            ;;
        --)
            shift
            break
            ;;
        -*)
            printf '%s\n' "prompt-nvim: unknown option: $1" >&2
            exit 2
            ;;
        *)
            break
            ;;
    esac
done

[ "$#" -gt 0 ] || {
    printf '%s\n' "prompt-nvim: missing prompt file" >&2
    exit 2
}

file="$1"

# The prompt file must be addressed absolutely: in --server mode the server
# opens it relative to ITS cwd, not ours, and the plugin keys the session on
# the normalized absolute path.
case "$file" in
    /*) abs_file="$file" ;;
    *) abs_file="$PWD/$file" ;;
esac

launch_cwd="$PWD"
session_id="${PROMPT_NVIM_SESSION:-p$$-$(od -An -N4 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n' || echo "$$")}"

export PROMPT_NVIM_TARGET="$target"
export PROMPT_NVIM_BRIDGE="$bridge"
export PROMPT_NVIM_CWD="$launch_cwd"
export PROMPT_NVIM_SESSION="$session_id"

# Raw-byte backup in a private temp dir. Cancellation restores from this
# (byte for byte); the launcher also restores it if the editor crashes.
backup=""
backup_dir=$(mktemp -d 2>/dev/null || echo "")
if [ -n "$backup_dir" ]; then
    backup="$backup_dir/backup"
    cp -p -- "$abs_file" "$backup" 2>/dev/null || backup=""
fi
export PROMPT_NVIM_BACKUP="$backup"

cleanup() {
    [ -n "$backup_dir" ] && rm -rf -- "$backup_dir" 2>/dev/null || true
}

# JSON string escaping for the server-mode spec (backslash then quote).
json_escape() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

status=0

if [ -n "$server" ]; then
    export PROMPT_NVIM_SERVER="$server"

    # Neovim has no --remote-wait (E5600), so we drive the server over
    # --remote-expr: open the prompt in it, then poll until the user closes the
    # buffer. Session metadata goes through a temp JSON file rather than an
    # inline --remote-expr literal so target/path characters never have to
    # survive shell -> VimL -> Lua escaping; the server reads and decodes it.
    if [ -z "$backup_dir" ]; then
        printf '%s\n' "prompt-nvim: cannot create a temp dir for --server mode" >&2
        exit 1
    fi

    bridge_bool=false
    [ "$bridge" = "1" ] && bridge_bool=true
    spec_file="$backup_dir/spec.json"
    printf '{"file":"%s","target":"%s","cwd":"%s","session_id":"%s","bridge":%s,"backup":"%s"}\n' \
        "$(json_escape "$abs_file")" \
        "$(json_escape "$target")" \
        "$(json_escape "$launch_cwd")" \
        "$(json_escape "$session_id")" \
        "$bridge_bool" \
        "$(json_escape "$backup")" >"$spec_file"

    opened=$("$nvim_cmd" --server "$server" \
        --remote-expr "luaeval('require(\"prompt.remote\").open_from_file(_A)', '$spec_file')" 2>/dev/null || echo 0)
    case "$opened" in
        *1*) ;;
        *)
            printf '%s\n' "prompt-nvim: server did not open the prompt (is prompt.nvim loaded there?)" >&2
            cleanup
            exit 1
            ;;
    esac

    # Poll until the session buffer closes (return/cancel). A missing/dead
    # server yields empty output -> treated as closed, so we never hang forever.
    while :; do
        open=$("$nvim_cmd" --server "$server" \
            --remote-expr "luaeval('require(\"prompt.remote\").is_open(_A)', '$session_id')" 2>/dev/null || echo 0)
        case "$open" in
            *1*) sleep 0.2 ;;
            *) break ;;
        esac
    done

    cleanup
    exit 0
fi

# Fresh process. Not exec'd, so we can restore the backup on a crash and clean
# up. Normal cancel is byte-restored in-plugin; this is the crash safety net.
"$nvim_cmd" "$@" || status=$?
if [ "$status" -gt 128 ] && [ -n "$backup" ] && [ -f "$backup" ]; then
    cp -- "$backup" "$abs_file" 2>/dev/null || true
fi
cleanup
exit "$status"
